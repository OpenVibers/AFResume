---
// Pacific Northwest hero — layered SVG mountains, particles, animated title,
// portrait slot, metrics ribbon.
---
<section class="hero" id="top">
  <!-- Parallax mountain layers -->
  <div class="hero__sky" aria-hidden="true"></div>
  <div id="hero-particles" class="hero__particles" aria-hidden="true"></div>

  <svg class="hero__mtn hero__mtn--3" viewBox="0 0 1440 600" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0,520 L120,360 L260,440 L420,300 L580,420 L740,280 L900,400 L1060,320 L1220,420 L1440,340 L1440,600 L0,600 Z" fill="#0c1a2c"/>
  </svg>
  <svg class="hero__mtn hero__mtn--2" viewBox="0 0 1440 600" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0,560 L160,440 L320,500 L500,380 L660,480 L820,360 L980,460 L1160,380 L1320,500 L1440,420 L1440,600 L0,600 Z" fill="#10243b"/>
  </svg>
  <svg class="hero__mtn hero__mtn--1" viewBox="0 0 1440 600" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0,580 L200,500 L380,540 L560,460 L760,520 L940,440 L1120,520 L1300,460 L1440,500 L1440,600 L0,600 Z" fill="#16314f"/>
  </svg>

  <div class="container hero__grid">
    <div class="hero__left">
      <div class="section-eyebrow"><i class="fa-solid fa-location-dot"></i> Seattle · Arlington · Pacific Northwest</div>
      <h1 class="hero__title" data-splitting>Alex Frison.</h1>
      <p class="hero__role">
        <span class="hero__rotator" aria-live="polite"><i class="fa-solid fa-chart-line"></i> Data Analyst</span>
      </p>
      <p class="hero__lead">
        Data analyst and systems architect with 10+ years of shipping — from
        SOX-compliance tooling and autonomous AI agents at Amazon ICQA to a
        solo-built 15-microservice open-source creator platform.
        Open to new roles.
      </p>
      <div class="hero__cta">
        <a href="/#work" class="btn btn--primary"><i class="fa-solid fa-eye"></i> View Work</a>
        <a href="/Alex_Frison_Resume_2026.pdf" class="btn" aria-label="Download resume as PDF"><i class="fa-solid fa-file-pdf"></i> PDF</a>
        <a href="/Alex_Frison_Resume_2026.docx" class="btn" aria-label="Download resume as Word document" download><i class="fa-solid fa-file-word"></i> DOCX</a>
        <a href="/#contact" class="btn"><i class="fa-solid fa-envelope"></i> Get in Touch</a>
      </div>
      <div class="hero__chips">
        <span class="chip"><i class="fa-solid fa-chart-line"></i> Analytics / BI</span>
        <span class="chip"><i class="fa-solid fa-code"></i> Full-Stack Eng</span>
        <span class="chip"><i class="fa-solid fa-robot"></i> Autonomous Agents</span>
        <span class="chip"><i class="fa-solid fa-gear"></i> Robotics / AFM</span>
        <span class="chip"><i class="fa-solid fa-hammer"></i> Product Builder</span>
        <span class="chip"><i class="fa-solid fa-comment-dollar"></i> Sales</span>
        <span class="chip"><i class="fa-solid fa-users"></i> Management / Leadership</span>
      </div>
    </div>

    <div class="hero__right">
      <div class="hero__portrait">
        <div class="hero__portrait-glow" aria-hidden="true"></div>
        <div class="hero__portrait-frame">
          <div class="hero__portrait-placeholder" role="img" aria-label="Portrait of Alex Frison">
            <img src="/assets/img/alex-cut1.png" alt="Alex Frison" class="hero__portrait-img hero__portrait-img--a" id="portrait-a">
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="hero__metrics container" aria-label="At a glance">
    <div><i class="fa-solid fa-server"></i><strong>200k+</strong><span>game servers tracked</span></div>
    <div><i class="fa-solid fa-magnifying-glass-chart"></i><strong>1000+</strong><span>IRDRs researched (SOX compliance)</span></div>
    <div><i class="fa-solid fa-calendar-days"></i><strong>10+</strong><span>years shipping</span></div>
    <div><i class="fa-solid fa-wrench"></i><strong>50+</strong><span>tools built</span></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    padding: 100px 0 40px;
    overflow: hidden;
    isolation: isolate;
  }
  .hero__sky {
    position: absolute; inset: 0;
    background:
      radial-gradient(1200px 600px at 70% 10%, rgba(76,201,176,.18), transparent 60%),
      radial-gradient(900px 500px at 20% 30%, rgba(244,162,97,.12), transparent 60%);
    z-index: -3;
  }
  .hero__particles { position: absolute; inset: 0; z-index: -2; }
  .hero__mtn {
    position: absolute; left: 0; right: 0;
    width: 100%; height: 60%;
    bottom: 0;
    z-index: -1;
    will-change: transform;
  }
  .hero__mtn--3 { bottom: 12%; opacity: .6; }
  .hero__mtn--2 { bottom: 6%;  opacity: .8; }
  .hero__mtn--1 { bottom: 0;   opacity: 1; }

  .hero__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(24px, 4vw, 64px);
    align-items: center;
    min-height: 70vh;
  }
  @media (max-width: 880px) {
    .hero__grid { grid-template-columns: 1fr; }
  }

  .hero__title {
    font-size: clamp(3rem, 9vw, 6.5rem);
    background: linear-gradient(180deg, #fff 30%, #8aa0b6 100%);
    -webkit-background-clip: text; background-clip: text;
    color: transparent;
    margin-bottom: 0.4em;
  }
  .hero__role {
    font-family: var(--font-display);
    font-size: clamp(2.5rem,2.4vw,2.5rem);
    color: var(--accent);
    margin: 0 0 1rem;
    min-height: 1.6em;
  }
  .hero__rotator { display: inline-block; }
  .hero__lead {
    max-width: 56ch;
    color: var(--muted);
    font-size: 1.06rem;
  }
  .hero__cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 1.5rem 0; }
  .hero__chips { display: flex; gap: 8px; flex-wrap: wrap; }

  .hero__right { display: grid; place-items: center; }
  .hero__portrait {
    position: relative;
    width: min(360px, 80vw);
    aspect-ratio: 5 / 6;
  }
  .hero__portrait-glow {
    position: absolute; inset: -10%;
    background: radial-gradient(closest-side, rgba(76,201,176,.35), transparent 70%);
    filter: blur(20px);
    animation: breathe 8s ease-in-out infinite;
  }
  .hero__portrait-frame {
    position: relative;
    width: 100%; height: 100%;
    border-radius: 28px;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    background: var(--surface);
    box-shadow: var(--shadow-card), var(--shadow-glow);
    animation: float 12s ease-in-out infinite;
  }
  .hero__portrait-placeholder { position: relative; width: 100%; height: 100%; overflow: hidden; }
  .hero__portrait-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: opacity 0.8s ease;
  }
  .hero__portrait-img--a { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    .hero__portrait-img { transition: none; }
  }
  .hero__portrait-tag {
    margin-top: 14px; text-align: center;
    color: var(--dim); font-size: .8rem;
  }
  .hero__portrait-tag code {
    color: var(--accent); font-family: var(--font-mono); font-size: .78rem;
  }

  @keyframes breathe {
    0%, 100% { opacity: .55; transform: scale(1); }
    50%      { opacity: .9;  transform: scale(1.05); }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-6px); }
  }

  .hero__metrics {
    margin-top: clamp(40px, 6vw, 72px);
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    padding: 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(14px);
  }
  .hero__metrics > div {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    padding: 8px;
  }
  .hero__metrics > div i {
    font-size: 1.4rem;
    color: var(--accent);
    margin-bottom: 6px;
    opacity: 0.85;
  }
  .hero__metrics strong {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: var(--accent);
  }
  .hero__metrics span { font-size: .8rem; color: var(--muted); margin-top: 4px; }
  @media (max-width: 600px) {
    .hero__metrics { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  // Title char reveal via Splitting
  const splitScript = document.createElement("script");
  splitScript.src = "/assets/vendor/splitting/splitting.min.js";
  splitScript.onload = () => {
    // @ts-ignore
    if (window.Splitting) Splitting();
    document.querySelectorAll(".hero__title .char").forEach((c, i) => {
      (c as HTMLElement).style.setProperty("--i", String(i));
    });
  };
  document.head.appendChild(splitScript);

  // Role rotator
  const roles = [
    `<i class="fa-solid fa-chart-line"></i> Data Analyst`,
    `<i class="fa-solid fa-code"></i> Software Engineer`,
    `<i class="fa-solid fa-robot"></i> Autonomous Agent Builder`,
    `<i class="fa-solid fa-server"></i> Systems Admin`,
    `<i class="fa-solid fa-cube"></i> Product Engineer`,
    `<i class="fa-brands fa-twitch"></i> Streaming Platform Builder`,
    `<i class="fa-solid fa-tree"></i> Pacific Northwest Native`,
    `<i class="fa-solid fa-comment-dollar"></i> Sales`,
    `<i class="fa-solid fa-users"></i> Management / Leadership`
  ];
  const rot = document.querySelector(".hero__rotator");
  if (rot && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    let i = 0;
    setInterval(() => {
      i = (i + 1) % roles.length;
      (rot as HTMLElement).animate(
        [{ opacity: 1, transform: "translateY(0)" },
         { opacity: 0, transform: "translateY(-6px)" }],
        { duration: 280, easing: "ease-in", fill: "forwards" }
      ).onfinish = () => {
        rot.innerHTML = roles[i];
        (rot as HTMLElement).animate(
          [{ opacity: 0, transform: "translateY(6px)" },
           { opacity: 1, transform: "translateY(0)" }],
          { duration: 280, easing: "ease-out", fill: "forwards" }
        );
      };
    }, 2600);
  }

  // Mountain parallax
  const m1 = document.querySelector(".hero__mtn--1") as HTMLElement | null;
  const m2 = document.querySelector(".hero__mtn--2") as HTMLElement | null;
  const m3 = document.querySelector(".hero__mtn--3") as HTMLElement | null;
  if (m1 && m2 && m3) {
    let raf = 0;
    const onScroll = () => {
      const y = window.scrollY;
      m1.style.transform = `translateY(${y * 0.06}px)`;
      m2.style.transform = `translateY(${y * 0.12}px)`;
      m3.style.transform = `translateY(${y * 0.20}px)`;
      raf = 0;
    };
    window.addEventListener("scroll", () => {
      if (!raf) raf = requestAnimationFrame(onScroll);
    }, { passive: true });
  }



  // tsparticles light rain/snow
  const ps = document.createElement("script");
  ps.src = "/assets/vendor/tsparticles/tsparticles.slim.bundle.min.js";
  ps.onload = async () => {
    // @ts-ignore
    if (!window.tsParticles) return;
    // @ts-ignore
    await window.tsParticles.load({
      id: "hero-particles",
      options: {
        fullScreen: { enable: false },
        background: { color: "transparent" },
        fpsLimit: 60,
        particles: {
          number: { value: 60, density: { enable: true, area: 900 } },
          color: { value: ["#4cc9b0", "#7aa2f7", "#ffffff"] },
          opacity: { value: { min: 0.15, max: 0.55 } },
          size: { value: { min: 0.5, max: 1.8 } },
          move: {
            enable: true, speed: 0.6, direction: "bottom",
            outModes: { default: "out" }, straight: false,
          },
          shape: { type: "circle" },
        },
        detectRetina: true,
      },
    });
  };
  document.head.appendChild(ps);
</script>
