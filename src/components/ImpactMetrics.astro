---
const metrics = [
  { num: "1,000+", label: "SOX-compliance IRDRs researched at Amazon", icon: "fa-solid fa-magnifying-glass-chart" },
  { num: "15",     label: "OpenVibe microservices built solo",         icon: "fa-solid fa-cubes-stacked" },
  { num: "200K+",  label: "Live game servers tracked",                 icon: "fa-solid fa-tower-broadcast" },
  { num: "20+",    label: "Automation scripts for Amazon workflows",   icon: "fa-solid fa-code" },
  { num: "10+",    label: "Years running my own LLC",                  icon: "fa-solid fa-building-flag" },
];
---
<section class="impact" aria-labelledby="impact-title" data-reveal>
  <div class="container">
    <header class="impact__head">
      <div class="section-eyebrow"><i class="fa-solid fa-bolt"></i> Impact at a glance</div>
      <h2 id="impact-title" class="section-title">Real numbers from real work</h2>
    </header>
    <ul class="impact__grid">
      {metrics.map(m => (
        <li class="impact__card">
          <i class={`${m.icon} impact__icon`} aria-hidden="true"></i>
          <span class="impact__num">{m.num}</span>
          <span class="impact__lbl">{m.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .impact { padding: clamp(40px, 6vw, 64px) 0 clamp(24px, 4vw, 40px); }
  .impact__head { text-align: center; margin-bottom: clamp(20px, 3vw, 32px); }
  .impact__head .section-title { margin: 0 auto; }
  .impact__grid {
    list-style: none; padding: 0; margin: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: clamp(10px, 1.6vw, 18px);
  }
  @media (max-width: 980px) { .impact__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 580px) { .impact__grid { grid-template-columns: repeat(2, 1fr); } }
  .impact__card {
    background: linear-gradient(180deg, var(--surface) 0%, color-mix(in srgb, var(--surface) 80%, transparent) 100%);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px 16px 18px;
    display: flex; flex-direction: column; align-items: center; text-align: center;
    gap: 8px;
    position: relative;
    transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
  }
  .impact__card:hover {
    transform: translateY(-4px);
    border-color: rgba(76,201,176,0.35);
    box-shadow: 0 12px 40px -12px rgba(76,201,176,0.3), 0 0 0 1px rgba(76,201,176,0.08);
  }
  .impact__icon {
    font-size: 1.05rem;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    width: 34px; height: 34px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 50%;
  }
  .impact__num {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 2.6vw, 2.1rem);
    font-weight: 700;
    color: var(--fg);
    line-height: 1.05;
  }
  .impact__lbl {
    font-size: .82rem;
    color: var(--muted);
    line-height: 1.35;
  }
</style>
