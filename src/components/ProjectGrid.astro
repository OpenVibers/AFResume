---
import { getCollection } from "astro:content";
const all = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);
const cats = ["all", ...new Set(all.map((p) => p.data.category))];

const catIcon: Record<string, string> = {
  amazon:   "fa-brands fa-aws",
  hobo:     "fa-solid fa-campground",
  python:   "fa-brands fa-python",
  game:     "fa-solid fa-gamepad",
  hardware: "fa-solid fa-microchip",
  web:      "fa-solid fa-globe",
  "3d":     "fa-solid fa-cube",
  tools:    "fa-solid fa-screwdriver-wrench",
};
const filterIcon: Record<string, string> = {
  all:      "fa-solid fa-border-all",
  ...catIcon,
};
---
<section class="grid-sec" id="portfolio">
  <div class="container">
    <div class="section-eyebrow"><i class="fa-solid fa-layer-group"></i> Portfolio</div>
    <h2 class="section-title">All work</h2>
    <div class="filters" role="tablist">
      {cats.map((c, i) => (
        <button class={`filter ${i === 0 ? "is-active" : ""}`} data-filter={c} role="tab">
          {filterIcon[c] && <i class={filterIcon[c]}></i>}{c}
        </button>
      ))}
    </div>
    <div class="proj-grid">
      {all.map((p) => (
        <a href={`/portfolio/${p.slug}`} class="proj card" data-cat={p.data.category} data-reveal>
          <div class="proj__head">
            <span class={`chip chip--${p.data.category}`}>
              {catIcon[p.data.category] && <i class={catIcon[p.data.category]}></i>}
              {p.data.category}
            </span>
            {p.data.year && (
              <span class="proj__year">
                <i class="fa-regular fa-calendar"></i> {p.data.year}
              </span>
            )}
          </div>
          <h3>{p.data.title}</h3>
          <p>{p.data.summary}</p>
          <ul class="proj__tech">
            {p.data.tech.slice(0, 4).map((t) => <li><i class="fa-solid fa-tag"></i>{t}</li>)}
          </ul>
          <div class="proj__cta">
            <i class="fa-solid fa-arrow-up-right-from-square"></i> View Project
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 1.6rem; }
  .filter {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: 999px;
    border: 1px solid var(--border);
    background: transparent; color: var(--muted);
    font: 500 .82rem var(--font-mono);
    cursor: pointer;
    text-transform: capitalize;
    transition: all .2s var(--ease);
  }
  .filter i { font-size: 0.78rem; }
  .filter:hover { color: var(--fg); border-color: var(--border-strong); }
  .filter.is-active { background: var(--accent); color: #06221c; border-color: transparent; }

  .proj-grid {
    display: grid; gap: 18px;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .proj {
    display: flex; flex-direction: column;
    color: var(--fg); text-decoration: none;
    transition: transform .3s var(--ease), border-color .3s var(--ease);
  }
  .proj:hover { text-decoration: none; transform: translateY(-4px); border-color: var(--accent); }
  .proj:hover .proj__cta { color: var(--accent); gap: 8px; }
  .proj.is-hidden { display: none; }
  .proj__head { display: flex; justify-content: space-between; align-items: center; margin-bottom: .8rem; }
  .proj__year {
    color: var(--dim); font-family: var(--font-mono); font-size: .78rem;
    display: inline-flex; align-items: center; gap: 4px;
  }
  .proj__year i { font-size: 0.72rem; }
  .proj h3 { font-family: var(--font-display); font-size: 1.15rem; margin: 0 0 .5rem; }
  .proj p  { font-size: .92rem; }
  .proj__tech {
    list-style: none; margin: auto 0 0; padding: 0;
    display: flex; gap: 6px; flex-wrap: wrap;
    padding-bottom: 0.6rem;
  }
  .proj__tech li {
    font: 500 .7rem var(--font-mono);
    color: var(--dim);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 2px 7px;
    display: inline-flex; align-items: center; gap: 4px;
  }
  .proj__tech li i { font-size: 0.6rem; color: var(--accent); opacity: 0.6; }

  .proj__cta {
    display: inline-flex; align-items: center; gap: 5px;
    margin-top: 0.8rem;
    font: 600 0.82rem var(--font-body);
    color: var(--muted);
    transition: color .2s var(--ease), gap .2s var(--ease);
    border-top: 1px solid var(--border);
    padding-top: 0.8rem;
  }
  .proj__cta i { font-size: 0.75rem; }

  /* Category chip accent colors */
  .chip--amazon   { color: #ff9900; border-color: rgba(255,153,0,.3); }
  .chip--hobo     { color: #4cc9b0; border-color: rgba(76,201,176,.3); }
  .chip--python   { color: #4b8bbe; border-color: rgba(75,139,190,.3); }
  .chip--game     { color: #f4a261; border-color: rgba(244,162,97,.3); }
  .chip--hardware { color: #7aa2f7; border-color: rgba(122,162,247,.3); }
  .chip--web      { color: #9ece6a; border-color: rgba(158,206,106,.3); }
  .chip--3d       { color: #bb9af7; border-color: rgba(187,154,247,.3); }
  .chip--tools    { color: #e0af68; border-color: rgba(224,175,104,.3); }
  .chip { display: inline-flex; align-items: center; gap: 5px; }
  .chip i { font-size: 0.75em; }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".filter").forEach((btn) => {
    btn.addEventListener("click", () => {
      const f = btn.dataset.filter;
      document.querySelectorAll(".filter").forEach((b) => b.classList.remove("is-active"));
      btn.classList.add("is-active");
      document.querySelectorAll<HTMLAnchorElement>(".proj").forEach((card) => {
        const show = f === "all" || card.dataset.cat === f;
        card.classList.toggle("is-hidden", !show);
      });
    });
  });
</script>
