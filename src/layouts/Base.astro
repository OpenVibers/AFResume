---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const {
  title = "Alex Frison — Software Engineer · Data Analyst · Builder",
  description = "Alex Frison: Seattle-based data analyst, software engineer, and product builder. Amazon ICQA analytics, autonomous research agents, OpenVibe streaming products, and a decade of shipping web platforms.",
  image = "/assets/img/og.png",
  canonical,
} = Astro.props;

const pageUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---
<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={pageUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#0a1018" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:url" content={pageUrl} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="Alex Frison" />
  <meta name="keywords" content="Alex Frison, Data Analyst, Software Engineer, Seattle, Arlington WA, Amazon ICQA, SQL, Python, TypeScript, Node.js, React, Full-Stack Developer, Autonomous Agents, AI Agent Builder, Systems Architect, SOX Compliance, Open Source, Pacific Northwest" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Alex Frison",
    "url": "https://alexfrison.net",
    "email": "alex@alexfrison.net",
    "telephone": "+14253673997",
    "image": "https://alexfrison.net/assets/img/alex-cut1.png",
    "jobTitle": "Data Analyst · Software Engineer",
    "description": "Seattle-area data analyst and full-stack software engineer with 10+ years shipping web platforms, autonomous analytics agents, and creator infrastructure. Open to new roles.",
    "knowsAbout": [
      "Data Analysis", "SQL", "Python", "TypeScript", "Node.js",
      "Machine Learning", "Autonomous Agents", "Streaming Platforms",
      "Systems Architecture", "SOX Compliance", "React", "MongoDB",
      "Redis", "NGINX", "Linux", "Excel", "Power Query"
    ],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Arlington",
      "addressRegion": "WA",
      "addressCountry": "US"
    },
    "sameAs": [
      "https://github.com/OpenVibers",
      "https://www.linkedin.com/in/fris/"
    ]
  }
  </script>

  <link rel="stylesheet" href="/assets/vendor/fontawesome/css/all.min.css" />
  <link rel="stylesheet" href="/assets/vendor/splitting/splitting.css" />
  <link rel="stylesheet" href="/assets/vendor/swiper/swiper-bundle.min.css" />
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <Nav />
  <main id="main"><slot /></main>
  <Footer />

  <script>
    // Reveal-on-scroll — Web Animations API so OS reduced-motion can't suppress it
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          const el = e.target as HTMLElement;
          el.style.opacity = '1';
          el.style.transform = 'none';
          el.animate(
            [
              { opacity: 0, transform: 'translateY(24px)' },
              { opacity: 1, transform: 'translateY(0)' }
            ],
            { duration: 600, easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fill: 'forwards' }
          );
          io.unobserve(el);
        }
      }
    }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });
    document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));

    // Theme toggle
    const KEY = "afnet-theme";
    const saved = localStorage.getItem(KEY);
    if (saved) document.documentElement.dataset.theme = saved;
    document.addEventListener("click", (e) => {
      const t = e.target as HTMLElement;
      if (t.closest("[data-theme-toggle]")) {
        const next = document.documentElement.dataset.theme === "light" ? "dark" : "light";
        document.documentElement.dataset.theme = next;
        localStorage.setItem(KEY, next);
      }
    });
  </script>
</body>
</html>
