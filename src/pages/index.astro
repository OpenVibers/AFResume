---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Marquee from "../components/Marquee.astro";
import ProjectCarousel from "../components/ProjectCarousel.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import ExperienceTimeline from "../components/ExperienceTimeline.astro";
import SkillsGrid from "../components/SkillsGrid.astro";
import ContactBlock from "../components/ContactBlock.astro";
---
<Base>
  <Hero />
  <Marquee />

  <section class="profile" id="about">
    <div class="container profile__row">
      <div data-reveal>
        <div class="section-eyebrow"><i class="fa-solid fa-user"></i> Profile</div>
        <h2 class="section-title"><i class="fa-solid fa-user"></i> A versatile builder</h2>
        <p class="profile-para">
          <i class="fa-solid fa-microchip profile-para__icon"></i>
          <span>Data analyst and systems architect with 10+ years of shipping — from
          <strong>SOX-compliance tooling at Amazon ICQA</strong> to autonomous
          AI research agents to a <strong>15-microservice open-source platform
          kernel</strong>, all built and operated solo. Strong at translating
          operational context into production-grade tooling, stakeholder-ready
          analysis, and systems that actually scale.</span>
        </p>
        <p class="profile-para">
          <i class="fa-solid fa-store profile-para__icon"></i>
          <span>Before the tech career, I cut my teeth in retail sales at
          <strong>Verizon Wireless</strong> — first as a Sales Representative,
          then promoted to <strong>Assistant Manager</strong>. Quota-driven
          environment, high customer volume, team coaching, and the kind of
          communication pressure that either breaks you or makes you sharp.
          It made me sharp. That foundation — reading people, closing clearly,
          handling objections — still shows up every time I present data or
          walk a stakeholder through a decision.</span>
        </p>
        <p class="profile-para">
          <i class="fa-solid fa-screwdriver-wrench profile-para__icon"></i>
          <span>Tech-geek since 12, building computers and chasing bleeding-edge
          hardware. A decade running my own LLC, ten years tracking 200,000+
          live game servers, and 1,000+ IRDRs personally researched at Amazon.
          I ship fast and keep what works.</span>
        </p>
      </div>
      <aside class="card profile__facts" data-reveal>
        <h3><i class="fa-solid fa-circle-info" style="color:var(--accent);margin-right:.4rem"></i>Quick facts</h3>
        <ul>
          <li><strong><i class="fa-solid fa-location-dot"></i> Based</strong>Seattle / Arlington, WA</li>
          <li><strong><i class="fa-solid fa-briefcase"></i> Open to</strong>Hybrid · Remote · On-site PNW</li>
          <li><strong><i class="fa-solid fa-building-columns"></i> Founder</strong>GameServerStats, LLC</li>
          <li><strong><i class="fa-solid fa-laptop-code"></i> Last role</strong>Amazon · Data Analyst (ICQA)</li>
          <li><strong><i class="fa-solid fa-magnifying-glass"></i> Seeking</strong><span class="seek-groups"><span class="seek-group"><i class="fa-solid fa-chart-line"></i> Analyst · Data Engineer · BI</span><span class="seek-group"><i class="fa-solid fa-server"></i> IT · Systems · Robotics · Technician</span><span class="seek-group"><i class="fa-solid fa-people-group"></i> Sales · Leadership · Management</span><span class="seek-group"><i class="fa-solid fa-hammer"></i> Builder · Architect · Maker</span></span></li>
        </ul>
      </aside>
    </div>
  </section>

  <ProjectCarousel />
  <ProjectGrid />
  <ExperienceTimeline />
  <SkillsGrid />
  <ContactBlock />
</Base>

<style>
  .profile__row {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: clamp(20px, 4vw, 48px);
    align-items: start;
  }
  @media (max-width: 880px) { .profile__row { grid-template-columns: 1fr; } }
  .profile__facts h3 { font-family: var(--font-display); margin-bottom: .8rem; }
  .profile__facts ul { list-style: none; padding: 0; margin: 0; }
  .profile__facts li {
    display: grid; grid-template-columns: 110px 1fr;
    gap: 12px; padding: 8px 0;
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: .92rem;
  }
  .profile__facts li:first-child { border-top: 0; }
  .profile__facts strong { color: var(--accent); font-family: var(--font-mono); font-size: .8rem; text-transform: uppercase; letter-spacing: .08em; }

  .seek-groups { display: flex; flex-direction: column; gap: 3px; }
  .seek-group { font-size: .82rem; color: var(--muted); }
  .seek-group i { color: var(--accent); margin-right: .25rem; font-size: .75rem; }

  .profile-para {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1.2rem;
    line-height: 1.75;
  }
  .profile-para__icon {
    flex-shrink: 0;
    margin-top: .25rem;
    font-size: 1rem;
    color: var(--accent);
    width: 1.2rem;
    text-align: center;
  }
</style>
